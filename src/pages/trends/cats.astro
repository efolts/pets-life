---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import trendingData from '../../../data/trending-cats.json';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Trends', href: '/trends/' },
  { label: 'Cats' }
];

const catProducts = trendingData.products;
const lastUpdated = new Date(trendingData.lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title="Trending Cat Products"
  description="Discover the cat products gaining traction this week. Independently curated picks that real cat owners are buying and recommending."
>
  <div class="page-content">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />

      <header class="page-header">
        <h1>Trending Cat Products</h1>
        <p class="page-intro">The cat products real owners are loving right now. From fountains and scratchers to litter solutions and toys, these are the picks gaining serious momentum.</p>
        <p class="last-updated">Last updated: {lastUpdated}</p>
      </header>

      <div class="product-grid">
        {catProducts.map((product) => (
          <ProductCard
            title={product.title}
            description={product.description}
            imageUrl={product.imageUrl}
            affiliateUrl={product.affiliateUrl}
          />
        ))}
      </div>

      <section class="related-trends">
        <h2>More Trends</h2>
        <div class="related-links">
          <a href="/trends/dogs/" class="related-link">Dog Trends</a>
          <a href="/trending-pet-products-this-week/" class="related-link">All Trending This Week</a>
          <a href="/trends/" class="related-link">Trends Hub</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page-content {
    padding: 40px 0;
  }

  .page-header {
    margin-bottom: 36px;
  }

  .page-header h1 {
    font-family: 'Lato', sans-serif;
    font-size: 2.25rem;
    font-weight: 900;
    color: #1a1a1a;
    margin-bottom: 12px;
  }

  .page-intro {
    font-size: 1.05rem;
    color: #666;
    line-height: 1.7;
    max-width: 700px;
  }

  .last-updated {
    font-size: 0.85rem;
    color: #999;
    margin-top: 8px;
    font-style: italic;
  }

  .related-trends {
    margin-top: 56px;
  }

  .related-trends h2 {
    font-family: 'Lato', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 16px;
  }

  .related-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .related-link {
    display: inline-block;
    padding: 10px 24px;
    background: #e6f7f5;
    color: #00a498;
    border-radius: 24px;
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .related-link:hover {
    background: #00a498;
    color: #ffffff;
  }
</style>

---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_CONFIG, SEO_CONFIG } from '../config';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, any>;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = SEO_CONFIG.defaultOgImage,
  ogType = 'website',
  jsonLd
} = Astro.props;

const resolvedCanonical = canonicalUrl || Astro.url.href;
const fullTitle = title === SITE_CONFIG.title ? title : `${title} | ${SITE_CONFIG.title}`;

const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE_CONFIG.title,
  "url": SITE_CONFIG.url,
  "description": SITE_CONFIG.description,
  "publisher": {
    "@type": "Organization",
    "name": SITE_CONFIG.title,
    "url": SITE_CONFIG.url
  }
};

const structuredData = jsonLd || defaultJsonLd;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content={SITE_CONFIG.author} />

  <!-- Canonical URL -->
  <link rel="canonical" href={resolvedCanonical} />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: Lato + Open Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content={SITE_CONFIG.title} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}

  <!-- Twitter -->
  <meta name="twitter:card" content={SEO_CONFIG.twitterCard} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />}

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XHXLJQFKCC"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XHXLJQFKCC');
  </script>

  <style is:global>
    /* Reset */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    /* Base */
    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: #333;
      background: #ffffff;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Typography */
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Lato', sans-serif;
      line-height: 1.3;
      color: #1a1a1a;
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 900;
      margin-bottom: 0.75rem;
    }

    h2 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    h3 {
      font-size: 1.35rem;
      font-weight: 700;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    p {
      margin-bottom: 1rem;
    }

    a {
      color: #00a498;
      text-decoration: none;
      transition: color 0.2s;
    }

    a:hover {
      color: #008a80;
    }

    img {
      max-width: 100%;
      height: auto;
    }

    /* Container */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .container-narrow {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Utility */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }

    /* Product grid */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin: 32px 0;
    }

    @media (max-width: 1024px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .product-grid {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 1.75rem;
      }

      h2 {
        font-size: 1.4rem;
      }
    }

    /* Tables */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
      font-size: 0.95rem;
    }

    th, td {
      border: 1px solid #e0e0e0;
      padding: 12px 16px;
      text-align: left;
    }

    th {
      background: #f5f7f7;
      font-weight: 600;
      font-family: 'Lato', sans-serif;
    }

    tr:hover td {
      background: #fafafa;
    }

    /* Lists inside articles */
    article ul, article ol {
      margin: 0 0 1rem 1.5rem;
    }

    article li {
      margin-bottom: 0.4rem;
    }
  </style>
</head>
<body>
  <Nav />

  <main>
    <slot />
  </main>

  <Footer />
</body>
</html>

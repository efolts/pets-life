---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_CONFIG } from '../config';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  category: string;
  author?: string;
  coverImage?: string;
  updatedDate?: Date;
  slug?: string;
}

const {
  title,
  description,
  publishDate,
  category,
  author = 'Pets Life Team',
  coverImage,
  updatedDate,
  slug
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : null;

// Find category slug from config
const categorySlug = SITE_CONFIG.categories.find(
  c => c.name.toLowerCase() === category.toLowerCase()
)?.slug || category.toLowerCase().replace(/\s+/g, '-');

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: category, href: `/category/${categorySlug}/` },
  { label: title }
];

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  ...(coverImage && { "image": coverImage }),
  "author": {
    "@type": "Person",
    "name": author
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE_CONFIG.title,
    "url": SITE_CONFIG.url
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={coverImage}
  jsonLd={articleJsonLd}
>
  <article class="post-article">
    <div class="post-container">
      <Breadcrumbs items={breadcrumbs} />

      <header class="post-header">
        <a href={`/category/${categorySlug}/`} class="post-category-badge">{category}</a>
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <span class="post-author">By {author}</span>
          <span class="post-meta-divider">|</span>
          <time datetime={publishDate.toISOString()}>{formattedDate}</time>
          {formattedUpdatedDate && (
            <>
              <span class="post-meta-divider">|</span>
              <span class="post-updated">Updated: {formattedUpdatedDate}</span>
            </>
          )}
        </div>
      </header>

      {coverImage && (
        <div class="post-cover">
          <img src={coverImage} alt={title} width="800" height="450" />
        </div>
      )}

      <div class="post-disclosure">
        <strong>Disclosure:</strong> {SITE_CONFIG.affiliateDisclosure}
      </div>

      <div class="post-content">
        <slot />
      </div>

      <footer class="post-footer">
        <div class="post-share">
          <span class="share-label">Share this article:</span>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-button"
          >
            Twitter
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-button"
          >
            Facebook
          </a>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    padding: 32px 0 0;
  }

  .post-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .post-header {
    margin-bottom: 24px;
  }

  .post-category-badge {
    display: inline-block;
    background: #e6f7f5;
    color: #00a498;
    padding: 4px 14px;
    border-radius: 20px;
    font-family: 'Open Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 12px;
    transition: background-color 0.2s;
  }

  .post-category-badge:hover {
    background: #ccf0ed;
    color: #008a80;
  }

  .post-title {
    font-family: 'Lato', sans-serif;
    font-size: 2.25rem;
    font-weight: 900;
    color: #1a1a1a;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .post-meta {
    font-family: 'Open Sans', sans-serif;
    font-size: 0.88rem;
    color: #777;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .post-meta-divider {
    margin: 0 10px;
    color: #ccc;
  }

  .post-author {
    font-weight: 600;
    color: #555;
  }

  .post-cover {
    margin-bottom: 24px;
    border-radius: 12px;
    overflow: hidden;
  }

  .post-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-disclosure {
    background: #fffcf0;
    border: 1px solid #f0e6c0;
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 32px;
    font-size: 0.82rem;
    color: #7a6b3a;
    line-height: 1.6;
  }

  .post-disclosure strong {
    color: #5a4f2a;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #333;
  }

  .post-content :global(h2) {
    font-family: 'Lato', sans-serif;
    font-size: 1.65rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 8px;
    border-bottom: 2px solid #e6f7f5;
  }

  .post-content :global(h3) {
    font-family: 'Lato', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #2a2a2a;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(img) {
    border-radius: 8px;
    margin: 16px 0;
  }

  /* Amazon product card styling within post content */
  .post-content :global(.product-box) {
    background: #f8fafa;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 24px;
    margin: 24px 0;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .post-content :global(.product-box img) {
    width: 150px;
    height: 150px;
    object-fit: contain;
    flex-shrink: 0;
    border-radius: 8px;
    background: #fff;
    padding: 8px;
  }

  .post-content :global(.product-box .product-info) {
    flex: 1;
  }

  .post-content :global(.product-box .product-info h4) {
    font-family: 'Lato', sans-serif;
    font-size: 1.1rem;
    margin: 0 0 8px;
    color: #1a1a1a;
  }

  .post-content :global(.product-box .product-info p) {
    font-size: 0.9rem;
    color: #666;
    margin: 0 0 12px;
  }

  .post-content :global(.cta-button),
  .post-content :global(.amazon-button) {
    display: inline-block;
    background: #00a498;
    color: #ffffff;
    padding: 10px 22px;
    border-radius: 24px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background-color 0.2s, transform 0.2s;
  }

  .post-content :global(.cta-button:hover),
  .post-content :global(.amazon-button:hover) {
    background: #008a80;
    transform: translateY(-1px);
    color: #ffffff;
  }

  /* Pros / Cons */
  .post-content :global(.pros-cons) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 20px 0;
  }

  .post-content :global(.pros) {
    background: #eef9ee;
    border-left: 4px solid #3caa3c;
    padding: 16px;
    border-radius: 0 8px 8px 0;
  }

  .post-content :global(.cons) {
    background: #fdf0f0;
    border-left: 4px solid #e05555;
    padding: 16px;
    border-radius: 0 8px 8px 0;
  }

  .post-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #e8e8e8;
  }

  .post-share {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .share-label {
    font-size: 0.9rem;
    color: #777;
    font-weight: 600;
  }

  .share-button {
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 20px;
    font-size: 0.85rem;
    color: #555;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .share-button:hover {
    border-color: #00a498;
    color: #00a498;
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.65rem;
    }

    .post-content :global(.pros-cons) {
      grid-template-columns: 1fr;
    }

    .post-content :global(.product-box) {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .post-content :global(.product-box img) {
      width: 120px;
      height: 120px;
    }
  }
</style>
